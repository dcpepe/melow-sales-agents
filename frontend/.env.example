# Required: Claude API key
ANTHROPIC_API_KEY=your-api-key-here

# Optional: override Claude model
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: custom base URL for shareable deal room links
# NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app

# Granola API key (from Granola desktop app > Settings > API)
GRANOLA_API_KEY=your-granola-api-key-here

# Gmail OAuth2 (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/gmail/callback

# Vercel KV - automatically provided when you add KV from Vercel dashboard
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
